{
  "name": "locus-memory",
  "version": "0.1.0",
  "description": "Persistent memory plugin for Claude Code. Knows your project, remembers your decisions, costs almost nothing.",
  "type": "module",
  "main": "dist/server.js",
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node esbuild.config.ts",
    "dev": "node --watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "memory",
    "mcp",
    "ai-agent"
  ],
  "author": {
    "name": "Magnifico4625",
    "email": "vozol81@mail.ru",
    "url": "https://github.com/Magnifico4625"
  },
  "license": "MIT",
  "homepage": "https://github.com/Magnifico4625/locus",
  "repository": {
    "type": "git",
    "url": "https://github.com/Magnifico4625/locus.git"
  },
  "bugs": {
    "url": "https://github.com/Magnifico4625/locus/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25 || ^4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "sql.js": "^1.12.0"
  }
}
