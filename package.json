{
  "name": "locus-memory",
  "version": "3.1.1",
  "description": "Persistent project-aware memory for AI coding tools. Built on MCP. Knows your project, remembers your decisions, costs almost nothing.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "main": "dist/server.js",
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node esbuild.config.ts",
    "dev": "node --watch packages/core/src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "npm -w @locus/core run typecheck",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "memory",
    "mcp",
    "ai-agent"
  ],
  "author": {
    "name": "Magnifico4625",
    "email": "vozol81@mail.ru",
    "url": "https://github.com/Magnifico4625"
  },
  "license": "MIT",
  "homepage": "https://github.com/Magnifico4625/locus",
  "repository": {
    "type": "git",
    "url": "https://github.com/Magnifico4625/locus.git"
  },
  "bugs": {
    "url": "https://github.com/Magnifico4625/locus/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "rollup": ">=4.59.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
